# All variables are optional. With none set, the app runs fully offline in
# retrieval-only mode (local embeddings, file-based vector index).

# Enables generated answers with inline citations + groundedness verification.
ANTHROPIC_API_KEY=

# Model used for answer generation (only relevant when an API key is set).
ANTHROPIC_MODEL=claude-opus-4-8

# Set to "mock" to demo the full answer -> verifier pipeline offline with a
# scripted mock LLM. The mock intentionally appends one unsupported claim so
# you can watch the verifier catch it. Ignored when ANTHROPIC_API_KEY is set.
LLM_MODE=

# Postgres + pgvector connection string. When set, the pgvector store is used
# instead of the default file-based index (see docker-compose.yml).
# Example: postgresql://postgres:postgres@localhost:5433/grounded
PGVECTOR_URL=

# Custom HuggingFace endpoint for the one-time embedding model download,
# e.g. a corporate mirror. Leave empty to use huggingface.co.
HF_ENDPOINT=
